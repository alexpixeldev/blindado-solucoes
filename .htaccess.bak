<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /blindado/

    # Garantir barra final para /formulario
    RewriteRule ^formulario$ /blindado/formulario/ [R=301,L]

    # Opcional: forçar barra final para diretórios existentes sem trailing slash
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.+[^/])$ /%{REQUEST_URI}/ [R=301,L]
</IfModule>
